{
  "compilerOptions": {
    "baseUrl": "src",
    "jsx": "react-jsx",
    "lib": ["ES2015", "DOM", "ES2018.Promise"],
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "target": "ES2015",
    "module": "ESNext",
    "allowJs": true,
    "checkJs": false,
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "build",
    "dist"
  ]
}
